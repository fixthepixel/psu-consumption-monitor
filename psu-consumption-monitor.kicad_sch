	(uuid "111a6eb5-ae6d-41c1-92c5-1a0bd83a0985")
	(paper "USLetter")
	(title_block
		(title "ATX Current Monitor")
		(date "2025-12-13")
		(rev "1")
		(comment 1 "High-side current monitoring for ATX power rails")
		(comment 2 "Rails monitored: +12V, +5V, +3.3V, +5VSB")
		(comment 3 "Shunt-based measurement using precision low-ohmic resistors")
		(comment 4 "Current & bus voltage sensing via INA3221 (I²C)")
		(comment 5 "Designed for ATX-24 connector inline installation")
		(comment 6 "Kelvin shunt routing required for accurate measurements")
		(comment 7 "Controller calculates current, voltage, and power per rail")
		(comment 8 "Intended for diagnostics, logging, and PSU load analysis")
		(comment 9 "FixThePixel — ATX Current Monitor Project")
	)
